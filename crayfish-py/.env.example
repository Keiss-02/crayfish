# Shared signal file for web dashboard
SHARED_FILE=/home/g6/crayfish/feed_signal.txt
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# WiFi / ESP32 stepper control
ESP32_HOST=192.168.4.1
ESP32_PORT=80
ESP32_PATH=/move
ESP32_STEPS=200
ESP32_DIRECTION=CW

# Remote model API detection (preferred for Raspberry Pi storage savings)
REMOTE_DETECT_PROVIDER=roboflow
REMOTE_DETECT_URL=https://serverless.roboflow.com
REMOTE_DETECT_API_KEY=YOUR_ROBOFLOW_API_KEY_HERE
REMOTE_DETECT_MODEL=crayfish-4bvu4/2
REMOTE_DETECT_METHOD=POST

# Activation window and ROI
ACTIVATION_START=08:00
ACTIVATION_END=20:00
ROI_BOX=160,120,480,360

# Motion and egg filter settings
MOTION_THRESHOLD=5000
EGG_DETECT_RATIO=0.015
EGG_DETECT_PIXELS=2500
FRAME_INTERVAL=0.1
GEMINI_COOLDOWN=5

# Optional local YOLO fallback (disable on Raspi if you want only remote detection)
YOLO_ENABLED=false
YOLO_MODEL_PATH=/path/to/best.pt
YOLO_CONF_THRESHOLD=0.4
